NEXT_PUBLIC_API_URL=
# Full FastAPI v1 base URL including /api/v1 when it runs on a separate origin,
# for example http://localhost:8001/api/v1 in local development.
NEXT_PUBLIC_API_V1_URL=
NEXT_PUBLIC_APP_ORIGIN=https://dental.example.com
# Bot link shown on the "open in Telegram" gate when the app is opened outside Telegram.
NEXT_PUBLIC_BOT_URL=https://t.me/your_bot
# Yandex Maps JS API key — enables the in-app Yandex map location picker (best for
# Uzbekistan). Leave empty to use the OpenStreetMap picker instead.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
# Local/demo mode — register + login create a local account (no backend calls).
# Set to true for testing without a backend; remove/false to use the real API.
NEXT_PUBLIC_LOCAL_MODE=
