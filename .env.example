NEXT_PUBLIC_API_URL=
# Full FastAPI v1 base URL including /api/v1 when it runs on a separate origin,
# for example http://localhost:8001/api/v1 in local development.
NEXT_PUBLIC_API_V1_URL=
# Optional public S3/CDN base. Its origin is added to CSP img-src; leave empty
# when uploads are served through the app's own origin.
NEXT_PUBLIC_MEDIA_URL=
# Bot link shown on the "open in Telegram" gate when the app is opened outside Telegram.
NEXT_PUBLIC_BOT_URL=https://t.me/your_bot
# Support link shown in the patient profile. Only official Telegram hosts are accepted.
NEXT_PUBLIC_SUPPORT_URL=https://t.me/your_support
# Set true to require opening the deployed UI from Telegram.
NEXT_PUBLIC_TELEGRAM_ONLY=false
# Same-origin Django admin path used by /superstat (path only, never a full URL).
NEXT_PUBLIC_ADMIN_URL=admin
# Yandex Maps JS API key — enables the in-app Yandex map location picker (best for
# Uzbekistan). This value is public in the browser bundle: restrict it by allowed
# website origins in Yandex Console. Leave empty to use OpenStreetMap instead.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
# Local/demo mode — register + login create a local account (no backend calls).
# Development only. Never put real patient data into demo mode.
NEXT_PUBLIC_LOCAL_MODE=
